---
import { Image } from "@astrojs/image/components"

export interface Props {
  title: string
  school: string
  location: string
  years: string
  image: string
}
const { title, school, location, years, image } = Astro.props
---

<li class="bg-white shadow overflow-hidden sm:rounded-lg my-8">
  <div class="education-item flex justify-between px-4 py-5 sm:px-6">
    <div class="education-information">
      <h4 class="font-display school-name font-extrabold">{school}</h4>
      <h4 class="program-name">{title}</h4>
      <p>{years} | {location}</p>
    </div>
    <Image
      src={image}
      format={"webp"}
      alt={title}
      width={100}
      height={100}
      fit={"contain"}
      class={"no-border"}
    />
  </div>
  <div class="px-4 pt-0 pb-5 sm:px-6"><slot /></div>
</li>
