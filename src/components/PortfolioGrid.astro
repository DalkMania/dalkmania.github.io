---
import type { CollectionEntry } from "astro:content"
import PortfolioItem from "./PortfolioItem.astro"

export interface Props {
  portfolioItems: CollectionEntry<"portfolio">[]
}

const { portfolioItems } = Astro.props
---

<ul class="portfolio-grid" role="list">
  {portfolioItems.map((item, i) => <PortfolioItem item={item} eager={i < 3 ? true : false} />)}
</ul>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 1fr;
    gap: 2rem;
    align-items: center;
    justify-items: center;
    padding-bottom: 2rem;

    @media (max-width: 1023px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
    }
  }
</style>
