---
import { getCollection } from 'astro:content';
import ExperienceItem from "./ExperienceItem.astro"
const experienceItems = await getCollection('experience')
---

<div class="experience pt-5 pb-0 not-prose">
  <h3 class="font-display experience-title font-extrabold">Experience</h3>
  <ul class="experience-items">
    {
      experienceItems.map(item => (
        <ExperienceItem
          title={item.data.title}
          company={item.data.company}
          location={item.data.location}
          years={item.data.years}
          image={item.data.image}
        />
      ))
    }
  </ul>
</div>
