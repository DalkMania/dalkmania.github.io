---
import { Badge } from "@/components/ui/badge";
import { render, type CollectionEntry } from "astro:content";
import { Building2, Calendar, MapPin } from "lucide-react";

interface Props {
  experience: CollectionEntry<"experience">;
}

const { experience } = Astro.props;

const { Content } = await render(experience);
---

<div class="relative pl-8 not-last:pb-12">
  {/* Timeline line */}
  <div class="absolute left-0 top-2.5 h-full w-0.5 bg-muted group-first:h-[calc(100%-24px)] group-first:top-6">
    <div class="absolute h-3 w-3 -left-1.25 top-0 rounded-full border-2 border-primary bg-background"></div>
  </div>

  {/* Content */}
  <div class="space-y-3">
    <div class="flex items-center gap-3">
      <div class="shrink-0 size-9 bg-accent rounded-full flex items-center justify-center">
        <Building2 className="size-5 text-muted-foreground" />
      </div>
      <span class="text-lg font-semibold">{experience.data.company}</span>
    </div>
    <div>
      <h2 class="text-xl font-medium">{experience.data.title}</h2>
      <div class="flex items-center gap-2 mt-1 text-sm">
        <Calendar className="size-4" />
        <span>{experience.data.period}</span>
        <MapPin className="size-4" />
        <span>{experience.data.location}</span>
      </div>
    </div>
    <div class="text-muted-foreground [&>p]:mb-4"><Content /></div>
    <div class="flex flex-wrap gap-2">
      {
        experience.data.technologies.map((tech) => (
          <Badge key={tech} variant="secondary" className="rounded-full">
            {tech}
          </Badge>
        ))
      }
    </div>
  </div>
</div>
