---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"

export interface Props {
  item: CollectionEntry<"experience">
}

const {
  item: {
    data: { title, company, location, years, image },
  },
} = Astro.props
---

<li>
  <div class="experience-item">
    <div class="experience-information">
      <h4 class="experience-company">{company}</h4>
      <h4 class="experience-name">{title}</h4>
      <p>{years} | {location}</p>
    </div>
    <Image src={image} format={"webp"} alt={title} height={100} width={100} class={"no-border"} />
  </div>
</li>

<style>
  li {
    background: #fff;
    overflow: hidden;
    border-radius: 0.5rem;
    margin-block: 2rem;

    --tw-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    --tw-shadow-colored: 0 1px 3px 0 var(--tw-shadow-color), 0 1px 2px -1px var(--tw-shadow-color);
    box-shadow: var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow);

    &:first-child {
      padding-top: 1.25rem;
    }
  }

  .experience-item {
    display: flex;
    justify-content: space-between;
    padding: 1.25rem;
  }
</style>
