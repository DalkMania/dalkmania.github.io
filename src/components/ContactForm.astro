<div class="contact-form">
  <h3 class="text-gray-900 text-lg mb-1 font-bold title-font">Contact</h3>
  <form name="contact" method="POST" netlify-honeypot="bot-field" data-netlify="true" class="flex flex-col w-full">
    <p class="hidden">
      <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
    </p>
    <input
      name="name"
      class="bg-white rounded border border-gray-400 focus:outline-none focus:border-indigo-500 text-base px-4 py-2 mb-4"
      placeholder="Name"
      type="text"
      required
    />
    <input
      name="email"
      class="bg-white rounded border border-gray-400 focus:outline-none focus:border-indigo-500 text-base px-4 py-2 mb-4"
      placeholder="Email"
      type="email"
      required
    />
    <textarea
      name="message"
      class="bg-white rounded border border-gray-400 focus:outline-none h-32 focus:border-indigo-500 text-base px-4 py-2 mb-4 resize-none"
      placeholder="Message"
      required></textarea>
    <button
      type="submit"
      class="text-white bg-indigo-500 border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg"
      >Send Message</button
    >
    <input type="hidden" name="form-name" value="contact" />
  </form>
</div>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-inline: auto;
    padding-block: 0 2rem;
    width: 27rem;

    @media (max-width: 640px) {
      width: 100%;
    }

    h3 {
      align-self: start;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;

      input,
      textarea {
        padding: 0.5rem 1rem;
        border: 1px solid var(--clr-gray);
        border-radius: 0.25rem;
        outline: none;

        &:focus {
          border: 1px solid var(--clr-regal-blue);
          outline: 2px solid transparent;
          outline-offset: 2px;
        }
      }

      button {
        background-color: var(--clr-regal-blue);
        border-radius: 0.25rem;
        color: #fff;
        text-align: center;
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        padding-left: 1.5rem;
        padding-right: 1.5rem;

        &:hover {
          background-color: rgb(44, 82, 130);
          cursor: pointer;
        }
      }

      .hidden {
        display: none;
      }
    }
  }
</style>
