---
export interface Props {
  length: number
  currentUrl: string
  currentPage: number
  base: string
  prevUrl?: string
  nextUrl?: string
  lastUrl: string
}

const { length, currentPage, base } = Astro.props
const paginationList = Array.from({ length }, (_, i) => i + 1)
---

<nav aria-label="Porfolio pages" class="pagination">
  <ul>
    {
      paginationList.map(num => (
        <li>
          <a
            href={`${base}${num == 1 ? "" : "/" + num}`}
            class={`pagination__link ${currentPage == num ? "disabled active" : ""}`}
          >
            {num}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .pagination {
    display: flex;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;

    ul {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      position: relative;
      width: 100%;
      gap: 0.25rem;

      a {
        border: 1px solid rgb(209 213 219);
        padding-inline: 1rem;
        padding-block: 0.5rem;

        &.disabled,
        &.active {
          border: 1px solid var(--clr-regal-blue);
          background: var(--clr-regal-blue);
          color: #fff;
          pointer-events: none;
          cursor: default;
        }

        &:hover {
          border: 1px solid var(--clr-regal-blue);
          background: var(--clr-regal-blue);
          color: #fff;
        }
      }
    }
  }
</style>
